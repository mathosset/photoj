---
title: "Blog photographie – Reportages & actualités | Mathieu Thomasset"
description: "Actualités, reportages et projets personnels de Mathieu Thomasset, photographe basé à Montaigu-Vendée et membre Hans Lucas."
preferred_url: "https://www.mathieuthomasset.fr/blog"
---


<div class="big-spacer"></div>

<div id="wrapper">
  <div class="container-fluid">
    <div class="row">
    <% page_articles.each_with_index do |article, i| %>
        <article>
          <div class="col-xs-12 col-sm-6 col-lg-4">
            <% if article.data.thumbnail %>
            <a href="<%= article.url %>">
              <img src="<%= article.data.thumbnail %>" alt="<%= article.title %>" style="width:100%;height:auto;margin-bottom:10px" loading="lazy">
            </a>
            <% end %>
            <time>/// <%= article.date.strftime('%e %b %Y')%> ///</time>
            <h1>
              <%= article.title %>
            </h1>
            <a href="<%= article.url %>">
              <p><%= strip_tags(article.body).split.first(20).join(' ') %>…</p>
            </a></br>
            <!-- <a href="<%= article.url %>">Lire plus</a></br> -->
        </article>
        <% end %>
          <div class="spacer"></div>
      </div>

    </div>
  </div>
</div>


<div class="spacer"></div>
