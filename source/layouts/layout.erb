<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title><%= page_title %></title>
    <meta name="description" content="<%= page_description %>">
    <meta name="author" content="Mathieu Thomasset">
    <meta name="robots" content="index,follow">

    <% _is_homepage     = current_page.data.preferred_url == 'https://www.mathieuthomasset.fr' %>
    <% _is_blog_article = !current_page.data.date.nil? %>
    <% _og_image = _is_blog_article && current_page.data.thumbnail ? "https://www.mathieuthomasset.fr#{current_page.data.thumbnail}" : "https://www.mathieuthomasset.fr/images/moi.jpg" %>
    <% _og_url = current_page.data.preferred_url || current_page_url %>

    <!-- Twitter Card data -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:site" content="<%= data.site.twitter_handle %>">
    <meta name="twitter:title" content="<%= page_title %>">
    <meta name="twitter:description" content="<%= page_description %>">
    <meta name="twitter:creator" content="<%= data.site.twitter_handle %>">
    <meta name="twitter:image" content="<%= _og_image %>">

    <!-- Open Graph -->
    <meta property="og:title" content="<%= page_title %>"/>
    <meta property="og:type" content="<%= _is_blog_article ? 'article' : 'website' %>"/>
    <meta property="og:url" content="<%= _og_url %>"/>
    <meta property="og:image" content="<%= _og_image %>"/>
    <meta property="og:image:width" content="1024"/>
    <meta property="og:image:height" content="768"/>
    <meta property="og:description" content="<%= page_description %>"/>
    <meta property="og:site_name" content="<%= data.site.title %>"/>

    <% if current_page.data.preferred_url %>
      <link rel="canonical" href="<%= current_page.data.preferred_url %>">
    <% end %>

    <!-- Schema.org JSON-LD — LocalBusiness / ProfessionalService (toutes pages) -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": ["LocalBusiness", "ProfessionalService"],
      "name": "Mathieu Thomasset Photographe",
      "url": "https://www.mathieuthomasset.fr",
      "telephone": "+33695514679",
      "email": "mathieuthomasset@gmx.com",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Montaigu-Vendée",
        "addressRegion": "Pays de la Loire",
        "postalCode": "85600",
        "addressCountry": "FR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 46.9742683,
        "longitude": -1.3137452
      },
      "description": "Photographe professionnel en Vendée — portraits corporate, reportages d'entreprise, presse et institutions. Basé à Montaigu-Vendée, membre du Studio Hans Lucas. Intervient dans tout le Grand Ouest.",
      "priceRange": "€€",
      "areaServed": [
        { "@type": "AdministrativeArea", "name": "Vendée" },
        { "@type": "AdministrativeArea", "name": "Loire-Atlantique" },
        { "@type": "AdministrativeArea", "name": "Maine-et-Loire" },
        { "@type": "AdministrativeArea", "name": "Pays de la Loire" },
        { "@type": "City", "name": "Montaigu-Vendée" },
        { "@type": "City", "name": "Montaigu" },
        { "@type": "City", "name": "Nantes" },
        { "@type": "City", "name": "La Roche-sur-Yon" },
        { "@type": "City", "name": "Saint-Nazaire" }
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Prestations photographiques",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Portrait corporate en Vendée" }},
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Portrait professionnel et LinkedIn" }},
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Photographie artisans et savoir-faire Vendée" }},
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Reportage d'entreprise en Vendée" }},
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Reportage industriel Pays de la Loire" }},
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Photographie agricole Vendée" }},
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Reportage presse et photojournalisme" }},
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Photographe entreprise Nantes" }}
        ]
      },
      "memberOf": {
        "@type": "Organization",
        "name": "Studio Hans Lucas",
        "url": "https://hanslucas.com"
      },
      "sameAs": [
        "https://www.linkedin.com/in/mathosset",
        "https://twitter.com/mathosset",
        "https://www.instagram.com/mathosset",
        "https://www.facebook.com/mathosset"
      ]
    }
    </script>

    <!-- Schema.org JSON-LD — Person (entité auteur, toutes pages) -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Mathieu Thomasset",
      "url": "https://www.mathieuthomasset.fr/bio",
      "image": "https://www.mathieuthomasset.fr/images/moi.jpg",
      "jobTitle": "Photographe professionnel",
      "description": "Photographe de presse et photographe professionnel basé en Vendée. Carte de presse. Reportages pour AFP, Reuters et plus de 150 titres de presse nationale et régionale.",
      "telephone": "+33695514679",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Montaigu-Vendée",
        "addressRegion": "Pays de la Loire",
        "addressCountry": "FR"
      },
      "areaServed": ["Vendée", "Pays de la Loire", "Grand Ouest"],
      "memberOf": {
        "@type": "Organization",
        "name": "Hans Lucas",
        "url": "https://hanslucas.com"
      },
      "sameAs": [
        "https://www.linkedin.com/in/mathosset",
        "https://twitter.com/mathosset",
        "https://www.instagram.com/mathosset",
        "https://www.facebook.com/mathosset"
      ]
    }
    </script>

    <% unless _is_homepage %>
    <!-- Schema.org BreadcrumbList — pages internes -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://www.mathieuthomasset.fr" },
        <% if _is_blog_article %>
        { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://www.mathieuthomasset.fr/blog" },
        { "@type": "ListItem", "position": 3, "name": <%= current_page.data.title.to_s.to_json %>, "item": <%= current_page_url.to_json %> }
        <% else %>
        { "@type": "ListItem", "position": 2, "name": <%= current_page.data.title.to_s.to_json %>, "item": <%= (current_page.data.preferred_url || current_page_url).to_json %> }
        <% end %>
      ]
    }
    </script>
    <% end %>

    <% if _is_blog_article %>
    <!-- Schema.org Article — articles de blog -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": <%= (current_page.data.title_seo.to_s.empty? ? current_page.data.title.to_s : current_page.data.title_seo.to_s).to_json %>,
      "description": <%= current_page.data.description.to_s.to_json %>,
      "author": {
        "@type": "Person",
        "name": "Mathieu Thomasset",
        "url": "https://www.mathieuthomasset.fr/bio"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Mathieu Thomasset Photographe",
        "url": "https://www.mathieuthomasset.fr"
      },
      "datePublished": "<%= current_page.data.date.to_date.iso8601 %>",
      "url": <%= current_page_url.to_json %><% unless current_page.data.image_path.to_s.empty? %>,
      "image": <%= current_page.data.image_path.to_s.to_json %><% end %>
    }
    </script>
    <% end %>

    <%= yield_content :head %>

    <!-- Styles -->
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css">
    <!-- Font Awesome — non-bloquant (icons non critiques au premier rendu) -->
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css" media="print" onload="this.media='all'">
    <noscript><link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css"></noscript>
    <!-- GLightbox — non-bloquant (uniquement nécessaire à l'ouverture d'une lightbox) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox@3.2.0/dist/css/glightbox.min.css" media="print" onload="this.media='all'">
    <noscript><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox@3.2.0/dist/css/glightbox.min.css"></noscript>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="dns-prefetch" href="https://fonts.googleapis.com">
    <link rel="dns-prefetch" href="https://fonts.gstatic.com">
    <link href="https://fonts.googleapis.com/css2?family=Abel&family=Roboto:wght@300;400;700;900&display=swap" rel="stylesheet">
    <%= favicon_tag 'favicon.ico' %>
    <%= stylesheet_link_tag "normalize", "all" %>
  </head>

  <body class="<%= page_classes %>">
    <%= partial 'layouts/navbar' %>
    <%= yield %>
    <%= partial 'layouts/footer' %>

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <%# <script src="https://code.jquery.com/jquery-migrate-3.4.1.min.js"></script> %>
    
    <!-- Masonry + imagesLoaded -->
    <script src="https://unpkg.com/imagesloaded@4.1.4/imagesloaded.pkgd.min.js"></script>
    <script src="https://unpkg.com/masonry-layout@4.2.2/dist/masonry.pkgd.min.js"></script>

    <!-- GLightbox JS -->
    <script src="https://cdn.jsdelivr.net/npm/glightbox@3.2.0/dist/js/glightbox.min.js"></script>

    <!-- Bootstrap -->
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js"></script>

    <!-- Ton JS -->
    <%= javascript_include_tag "all" %>

    <!-- Google Ads & Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=AW-1022405015"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'AW-1022405015');
    </script>

    <% if current_page.data.preferred_url == 'https://www.mathieuthomasset.fr/confirmation-de-contact' %>
      <script>
        gtag('event', 'conversion', {'send_to': 'AW-1022405015/BnkYCJPx_8EBEJfTwucD'});
      </script>
    <% end %>
  </body>
</html>
