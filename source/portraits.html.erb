<% content_for :head do %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Combien co\u00fbte un portrait corporate en Vend\u00e9e ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Le tarif d\u00e9pend du nombre de personnes \u00e0 photographier, du lieu et du temps de prise de vue. Chaque demande fait l\u2019objet d\u2019un devis personnalis\u00e9, que ce soit pour un portrait de dirigeant, une \u00e9quipe ou un artisan en atelier."
      }
    },
    {
      "@type": "Question",
      "name": "O\u00f9 se d\u00e9roulent les s\u00e9ances photo ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Je r\u00e9alise les portraits directement sur site (entreprise, atelier, ferme, institution) ou avec un studio mobile install\u00e9 dans vos locaux. Je peux aussi travailler en lumi\u00e8re naturelle pour un rendu plus documentaire."
      }
    },
    {
      "@type": "Question",
      "name": "Quels usages pour les portraits professionnels ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Les portraits sont optimis\u00e9s pour vos sites internet, r\u00e9seaux professionnels comme LinkedIn, vos rapports annuels, communiqu\u00e9s de presse ou vos supports institutionnels. Ils mettent en valeur votre image tout en restant fid\u00e8les \u00e0 votre identit\u00e9."
      }
    },
    {
      "@type": "Question",
      "name": "R\u00e9alisez-vous des portraits LinkedIn professionnels en Vend\u00e9e ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui. Le portrait LinkedIn est l\u2019une de mes missions les plus fr\u00e9quentes. Un profil LinkedIn avec une photo professionnelle g\u00e9n\u00e8re significativement plus de vues et de prises de contact qu\u2019un profil sans photo ou avec une photo amateur. Je r\u00e9alise des portraits LinkedIn en Vend\u00e9e et dans le Grand Ouest, en studio mobile dans vos locaux ou en lumi\u00e8re naturelle, avec une livraison rapide des fichiers recadr\u00e9s au format LinkedIn (400\u00d7400 px minimum) et optimis\u00e9s pour le web."
      }
    }
  ]
}
</script>
<% end %>

